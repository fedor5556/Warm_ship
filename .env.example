# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-token-here

# Who is allowed to use the bot: comma-separated Telegram user IDs and/or usernames
# Example: ALLOWED_USERS=123456789,@friend_username
ALLOWED_USERS=

# Your numeric Telegram user ID (receives error alerts)
ADMIN_USER_ID=

# Optional: secondary bot token used to notify admin if the main bot crashes
CRASH_BOT_TOKEN=
